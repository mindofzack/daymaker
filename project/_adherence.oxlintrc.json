{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/controls/**",
              "components/display/**",
              "components/forms/**",
              "components/marine/**",
              "components/surfaces/**",
              "website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Figtree|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Figtree, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|ring|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, ring, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|solid|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, solid, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|go|caution|avoid|info)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'accent' | 'go' | 'caution' | 'avoid' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|uppercase|fullWidth|disabled|iconLeft|iconRight|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, uppercase, fullWidth, disabled, iconLeft, iconRight, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:elevated|hoverable|padding|media|children|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: elevated, hoverable, padding, media, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConditionBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|showValue|tone|height|style|key|ref|className|style|children)$/]",
        "message": "<ConditionBar> doesn't accept that prop. Declared props: value, label, showValue, tone, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConditionBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:go|caution|avoid|info)$/]",
        "message": "<ConditionBar> tone must be one of 'go' | 'caution' | 'avoid' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|label|disabled|children|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, size, label, disabled, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:surface|accent|ghost|outline)$/]",
        "message": "<IconButton> variant must be one of 'surface' | 'accent' | 'ghost' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:shape|size|iconLeft|iconRight|invalid|containerStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: shape, size, iconLeft, iconRight, invalid, containerStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:pill|box)$/]",
        "message": "<Input> shape must be one of 'pill' | 'box'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricTrend'] > JSXAttribute > JSXIdentifier[name!=/^(?:dir|value|key|ref|className|style|children)$/]",
        "message": "<MetricTrend> doesn't accept that prop. Declared props: dir, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricTrend'] > JSXAttribute[name.name='dir'] > Literal[value!=/^(?:up|down|flat)$/]",
        "message": "<MetricTrend> dir must be one of 'up' | 'down' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Recommendation'] > JSXAttribute > JSXIdentifier[name!=/^(?:verdict|title|summary|window|variant|style|key|ref|className|style|children)$/]",
        "message": "<Recommendation> doesn't accept that prop. Declared props: verdict, title, summary, window, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Recommendation'] > JSXAttribute[name.name='verdict'] > Literal[value!=/^(?:go|caution|avoid)$/]",
        "message": "<Recommendation> verdict must be one of 'go' | 'caution' | 'avoid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Recommendation'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:card|pill)$/]",
        "message": "<Recommendation> variant must be one of 'card' | 'pill'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|label|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, disabled, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:selected|onClick|removable|onRemove|children|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: selected, onClick, removable, onRemove, children, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
